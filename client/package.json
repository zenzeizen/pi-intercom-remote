{
  "name": "pi-intercom-remote",
  "version": "0.1.0",
  "description": "pi extension: connect two pi.dev coding-agent sessions on different machines through a WebSocket relay. Cross-machine sibling of pi-intercom.",
  "license": "MIT",
  "type": "module",
  "main": "index.ts",
  "files": [
    "index.ts",
    "types.ts",
    "config.ts",
    "relay-client.ts",
    "reply-tracker.ts",
    "wire-protocol.ts",
    "ui/**/*.ts",
    "skills/**/*",
    "README.md",
    "NOTICE.md"
  ],
  "keywords": [
    "pi-package",
    "pi-intercom",
    "pi.dev",
    "coding-agent",
    "relay",
    "intercom"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.5.0"
  }
}
