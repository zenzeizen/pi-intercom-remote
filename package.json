{
  "name": "pi-intercom-remote-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Cross-machine relay for pi.dev coding agent sessions.",
  "workspaces": [
    "shared",
    "relay",
    "client"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:relay": "npm run dev --workspace=relay",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
